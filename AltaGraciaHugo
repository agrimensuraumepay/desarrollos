<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Subdivisión LT 32 · Alta Gracia — Análisis de desarrollo</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#1c1b18; --ink-soft:#4a4843; --paper:#f6f3ec; --card:#fffdf8;
    --line:#e2ddd0; --line-soft:#ece8dd; --accent:#a8492a; --accent-2:#8a3b1e;
    --accent-soft:#f0e6df; --sage:#4f6b4a; --muted:#8a857a; --warn:#9a6a16;
    --mono:'IBM Plex Mono',monospace; --sans:'IBM Plex Sans',sans-serif; --serif:'Fraunces',serif;
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{margin:0;background:var(--paper);color:var(--ink);font-family:var(--sans);
    font-size:16px;line-height:1.65;-webkit-font-smoothing:antialiased;}
  .wrap{max-width:880px;margin:0 auto;padding:0 22px 80px;}

  header{background:var(--ink);color:var(--paper);padding:38px 0 34px;border-bottom:3px solid var(--accent);}
  .head-inner{max-width:880px;margin:0 auto;padding:0 22px;display:flex;align-items:center;gap:20px;flex-wrap:wrap;}
  .mark{width:54px;height:54px;border:1.5px solid var(--paper);border-radius:8px;display:flex;
    align-items:center;justify-content:center;font-family:var(--serif);font-weight:600;font-size:20px;letter-spacing:1px;flex-shrink:0;}
  .mark span{opacity:.55;margin:0 2px;}
  header h1{font-family:var(--serif);font-weight:600;font-size:26px;line-height:1.1;margin:0;}
  header .sub{font-size:14px;color:#cfc8b8;margin-top:4px;}
  .meta{margin-top:18px;display:flex;gap:26px;flex-wrap:wrap;font-family:var(--mono);font-size:12.5px;color:#bdb6a6;}
  .meta b{color:var(--paper);font-weight:500;}

  section{margin-top:52px;animation:rise .6s ease both;}
  @keyframes rise{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:none;}}
  h2{font-family:var(--serif);font-weight:600;font-size:22px;margin:0 0 4px;display:flex;align-items:baseline;gap:12px;}
  h2 .n{font-family:var(--mono);font-size:13px;color:var(--accent);font-weight:500;}
  h2::after{content:"";flex:1;height:1px;background:var(--line);margin-left:6px;align-self:center;}
  .lead{color:var(--ink-soft);margin:10px 0 22px;}

  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
  @media(max-width:620px){.grid2{grid-template-columns:1fr;}}
  .card{background:var(--card);border:1px solid var(--line);border-radius:12px;padding:18px 20px;}
  .card h3{font-family:var(--sans);font-weight:600;font-size:15px;margin:0 0 10px;letter-spacing:.2px;}
  ul.clean{list-style:none;padding:0;margin:0;}
  ul.clean li{padding:7px 0 7px 22px;position:relative;border-bottom:1px solid var(--line-soft);font-size:15px;}
  ul.clean li:last-child{border-bottom:none;}
  ul.clean li::before{content:"";position:absolute;left:4px;top:14px;width:7px;height:7px;border-radius:2px;background:var(--accent);}
  ul.clean li.ok::before{background:var(--sage);}
  ul.clean li.warn::before{background:var(--warn);}
  ul.clean b{font-weight:600;}

  table{width:100%;border-collapse:collapse;margin-top:6px;font-size:14.5px;}
  th,td{text-align:left;padding:9px 10px;border-bottom:1px solid var(--line-soft);}
  thead th{font-size:12px;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);border-bottom:1px solid var(--line);font-weight:600;}
  td.num,th.num{text-align:right;font-family:var(--mono);white-space:nowrap;}
  .tag{display:inline-block;font-size:11px;font-family:var(--mono);padding:2px 7px;border-radius:5px;border:1px solid var(--line);color:var(--ink-soft);}
  .tag.must{background:var(--accent-soft);border-color:#e0c9bb;color:var(--accent-2);}
  .tag.neg{background:#f3eddd;border-color:#e6d9b6;color:var(--warn);}
  .note{font-size:13px;color:var(--muted);margin-top:10px;line-height:1.55;}

  .app{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:20px;margin-top:6px;}
  .sumbar{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px;}
  @media(max-width:560px){.sumbar{grid-template-columns:1fr;}}
  .metric{background:var(--paper);border-radius:10px;padding:13px 15px;border:1px solid var(--line-soft);}
  .metric .k{font-size:12px;color:var(--muted);}
  .metric .val{font-family:var(--mono);font-size:23px;font-weight:500;margin-top:2px;}

  .tabs{display:flex;gap:2px;border-bottom:1px solid var(--line);}
  .tab-btn{appearance:none;border:none;background:none;font-family:var(--sans);font-size:14px;padding:10px 16px;
    cursor:pointer;color:var(--muted);border-bottom:2px solid transparent;margin-bottom:-1px;}
  .tab-btn.active{color:var(--accent);border-bottom-color:var(--accent);font-weight:600;}
  .panel{display:none;padding-top:20px;}
  .panel.active{display:block;}

  table.edit{width:100%;border-collapse:collapse;}
  table.edit th{font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);text-align:left;padding:4px 8px;border-bottom:1px solid var(--line);font-weight:600;}
  table.edit th.r{text-align:right;}
  table.edit td{padding:3px 4px;border-bottom:1px solid var(--line-soft);vertical-align:middle;}
  .cell-in{width:100%;border:1px solid transparent;background:transparent;padding:6px 8px;border-radius:6px;
    font-family:var(--sans);font-size:14px;color:var(--ink);}
  .cell-in:hover{border-color:var(--line);}
  .cell-in:focus{outline:none;border-color:var(--accent);background:var(--paper);}
  .cell-num{font-family:var(--mono);text-align:right;}
  .lblcell{font-family:var(--mono);font-size:13px;color:var(--muted);text-align:center;width:42px;}
  .del{appearance:none;border:none;background:none;color:var(--muted);cursor:pointer;font-size:18px;line-height:1;padding:5px 8px;border-radius:6px;}
  .del:hover{color:var(--accent);background:var(--accent-soft);}
  .subtot{display:flex;justify-content:space-between;align-items:center;margin-top:12px;padding-top:11px;border-top:1.5px solid var(--ink);font-weight:600;}
  .subtot .num{font-family:var(--mono);}
  .btn{appearance:none;font-family:var(--sans);font-size:13.5px;padding:8px 14px;border:1px solid var(--line);
    background:var(--paper);border-radius:8px;cursor:pointer;color:var(--ink);margin-top:12px;}
  .btn:hover{border-color:var(--accent);color:var(--accent);}

  .anchors{display:flex;gap:10px;flex-wrap:wrap;margin:6px 0 4px;}
  .anchor{display:flex;align-items:center;gap:6px;background:var(--paper);border:1px solid var(--line-soft);border-radius:8px;padding:6px 8px;}
  .anchor input{width:64px;border:1px solid transparent;background:transparent;font-family:var(--mono);font-size:13px;color:var(--ink);padding:3px 4px;border-radius:5px;text-align:right;}
  .anchor input:focus{outline:none;border-color:var(--accent);background:var(--card);}
  .anchor span{font-size:12px;color:var(--muted);}
  figure{margin:16px 0 8px;}
  figure img{width:100%;border:1px solid var(--line);border-radius:10px;background:#11171f;display:block;}
  figcaption{font-size:12.5px;color:var(--muted);margin-top:6px;text-align:center;}

  .slider label{display:flex;justify-content:space-between;font-size:13.5px;color:var(--ink-soft);margin-bottom:5px;}
  .slider label .v{font-family:var(--mono);font-weight:500;color:var(--ink);}
  input[type=range]{width:100%;accent-color:var(--accent);height:22px;}
  .slider{margin-bottom:16px;}
  .nums{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;}
  @media(max-width:560px){.nums{grid-template-columns:1fr;}}
  .nums label{font-size:13px;color:var(--ink-soft);display:block;margin-bottom:5px;}
  input[type=number].big{width:100%;padding:9px 11px;border:1px solid var(--line);border-radius:8px;font-family:var(--mono);font-size:15px;background:var(--paper);color:var(--ink);}
  input[type=number].big:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px rgba(168,73,42,.12);}
  .chk{display:flex;align-items:center;gap:9px;font-size:13.5px;color:var(--ink-soft);cursor:pointer;}
  .chk input{width:16px;height:16px;accent-color:var(--accent);}
  .bd{font-size:14.5px;margin-top:18px;}
  .bd .r{display:flex;justify-content:space-between;padding:6px 0;}
  .bd .r span:last-child{font-family:var(--mono);}
  .bd .r.t{border-top:1px solid var(--line);margin-top:5px;padding-top:9px;font-weight:600;}
  .bd .r .lbl{color:var(--ink-soft);}

  footer{margin-top:60px;padding-top:22px;border-top:1px solid var(--line);font-size:12.5px;color:var(--muted);line-height:1.6;}
  a{color:var(--accent);}
</style>
</head>
<body>

<header>
  <div class="head-inner">
    <div class="mark">A<span>|</span>U</div>
    <div>
      <h1>Subdivisión simple — LT 32, Alta Gracia</h1>
      <div class="sub">Análisis de desarrollo · modelo de referencia: Altos del Zorzal (Chivilcoy)</div>
    </div>
  </div>
  <div class="head-inner"><div class="meta">
    <span><b>Parcela</b> 3106010401184032</span>
    <span><b>Superficie</b> 19.745 m² (~2 ha)</span>
    <span><b>Lotes</b> 24 + pasaje</span>
    <span><b>Por</b> Agrimensura Umepay</span>
  </div></div>
</header>

<div class="wrap">

  <section>
    <h2><span class="n">01</span> Situación y normativa</h2>
    <p class="lead">El proyecto se encuadra como <b>subdivisión simple</b> (no loteo/urbanización), confirmado con la oficina de loteos de Alta Gracia. Esa decisión es la que define la economía: evita el Estudio de Impacto Ambiental, las cesiones del 15% y el paquete pesado de obras de una urbanización.</p>
    <div class="grid2">
      <div class="card">
        <h3>Dónde estamos</h3>
        <ul class="clean">
          <li>Parcela urbana de <b>~2 ha</b>, Barrio El Tiro Federal, esquina Manuel Alfonso y Concejal Rusconi — con frente a calles abiertas y servidas.</li>
          <li class="ok"><b>Título resuelto:</b> mensura de posesión (usucapión) a nombre de Hugo R. Leiva, aprobada y registrada en Catastro (Exp. 0033-67216/02).</li>
          <li><b>24 lotes</b> vendibles + <b>pasaje privado</b> interno (lote 25).</li>
        </ul>
      </div>
      <div class="card">
        <h3>Las tres compuertas regulatorias</h3>
        <ul class="clean">
          <li class="ok"><b>≤ 25 lotes (provincial):</b> con 24, sin EIA. Cumple.</li>
          <li class="ok"><b>≤ 10 lotes con frente al pasaje:</b> solo 5–6 frentistas. Cumple.</li>
          <li class="warn"><b>Municipal:</b> sin verde obligatorio, pero podría pedirse ~5% para laguna de retardo. A confirmar.</li>
        </ul>
      </div>
    </div>
    <div class="card" style="margin-top:14px;">
      <h3>El pasaje privado</h3>
      <p style="margin:0;font-size:15px;color:var(--ink-soft);">Máximo <b>75 m</b> (se proyectan ~70 m). Una vez aprobado y terminado en Catastro, se <b>cede al municipio</b>: conviene dejarlo presentable (cordón, ripio o adoquín) para que el municipio lo tome y no quede una parcela en condominio con las unidades.</p>
    </div>
  </section>

  <section>
    <h2><span class="n">02</span> Alcance de obra</h2>
    <p class="lead">Lo que exige la subdivisión simple, según la oficina de loteos. Mucho más liviano que una urbanización (que sumaría cloacas, planta de tratamiento, potabilización, pavimento de hormigón y EIA).</p>
    <table>
      <thead><tr><th>Ítem</th><th style="text-align:right;">Condición</th></tr></thead>
      <tbody>
        <tr><td>Tendido eléctrico domiciliario</td><td style="text-align:right;"><span class="tag must">Obligatorio</span></td></tr>
        <tr><td>Alumbrado público</td><td style="text-align:right;"><span class="tag must">Obligatorio</span></td></tr>
        <tr><td>Red de agua</td><td style="text-align:right;"><span class="tag must">Obligatorio</span></td></tr>
        <tr><td>Apertura + ripio del pasaje (70 m)</td><td style="text-align:right;"><span class="tag">Requerido</span></td></tr>
        <tr><td>Cordón cuneta</td><td style="text-align:right;"><span class="tag">Requerido</span></td></tr>
        <tr><td>Estudio de correntía / escurrimiento</td><td style="text-align:right;"><span class="tag">Requerido</span></td></tr>
        <tr><td>Laguna de retardo (% a dejar)</td><td style="text-align:right;"><span class="tag neg">A negociar</span></td></tr>
        <tr><td>Pavimento / adoquín del pasaje</td><td style="text-align:right;"><span class="tag neg">Opcional</span></td></tr>
      </tbody>
    </table>
  </section>

  <section>
    <h2><span class="n">03</span> Modelo de rentabilidad</h2>
    <p class="lead">App editable, todo en USD. Cargá los costos en su pestaña, ajustá el precio de cada lote en la de ventas, y la rentabilidad se recalcula sola. Los totales de arriba quedan siempre a la vista.</p>

    <div class="app" id="app">
      <div class="sumbar">
        <div class="metric"><div class="k">Ventas brutas</div><div class="val" id="mVen">—</div></div>
        <div class="metric"><div class="k">Costos totales</div><div class="val" id="mCos">—</div></div>
        <div class="metric"><div class="k">Ganancia del equipo</div><div class="val" id="mGan">—</div></div>
      </div>

      <div class="tabs">
        <button class="tab-btn active" data-tab="rent">Rentabilidad</button>
        <button class="tab-btn" data-tab="cost">Costos</button>
        <button class="tab-btn" data-tab="sale">Ventas</button>
      </div>

      <div class="panel active" id="p-rent">
        <div class="slider">
          <label><span>Vendido al pozo (resto a precio de lista, −25%)</span><span class="v" id="pozoVal">70%</span></label>
          <input type="range" id="pozo" min="0" max="100" step="5" value="70">
        </div>
        <div class="slider">
          <label><span>Reparto: % del valor para el dueño (Hugo)</span><span class="v" id="hugoVal">50%</span></label>
          <input type="range" id="hugo" min="0" max="100" step="5" value="50">
        </div>
        <div class="nums">
          <div><label>Honorarios fijos agrim + escrib (USD)</label><input type="number" class="big" id="honorFijo" value="30000" step="2000"></div>
          <div style="display:flex;align-items:flex-end;"><label class="chk"><input type="checkbox" id="honorTog" checked> Sumar honorarios internalizados (comisión 3% + fijos)</label></div>
        </div>
        <div class="bd" id="bd"></div>
      </div>

      <div class="panel" id="p-cost">
        <table class="edit" id="costTable">
          <thead><tr><th>Concepto</th><th class="r">USD</th><th></th></tr></thead>
          <tbody></tbody>
        </table>
        <div class="subtot"><span>Total costos</span><span class="num" id="costTotal">—</span></div>
        <button class="btn" id="addCost">+ Agregar fila</button>
      </div>

      <div class="panel" id="p-sale">
        <p style="font-size:14px;color:var(--ink-soft);margin:0 0 10px;">El precio de cada lote sale de una <b>interpolación lineal por tramos</b> entre estos anclajes (superficie → valor). El primer tramo vale ~USD 20/m² sobre la base; arriba de 1000 m², ~USD 10/m². Editá los anclajes y recalculá, o cambiá el precio de cada lote a mano.</p>
        <div class="anchors" id="anchors">
          <div class="anchor"><input class="asrf" type="number" value="500"><span>m² →</span><input class="aval" type="number" value="25000"><span>USD</span></div>
          <div class="anchor"><input class="asrf" type="number" value="1000"><span>m² →</span><input class="aval" type="number" value="35000"><span>USD</span></div>
          <div class="anchor"><input class="asrf" type="number" value="1500"><span>m² →</span><input class="aval" type="number" value="40000"><span>USD</span></div>
        </div>
        <button class="btn" id="recalc">Recalcular precios desde la regla</button>

        <figure>
          <img src="data:image/png;base64," alt="Distribución parcelaria de la subdivisión: 24 lotes y el pasaje interno">
          <figcaption>Distribución parcelaria (referencia) — 24 lotes + pasaje (lote 25)</figcaption>
        </figure>

        <table class="edit" id="lotTable">
          <thead><tr><th>Lote</th><th class="r">Sup. m²</th><th class="r">Precio USD (lista)</th><th></th></tr></thead>
          <tbody></tbody>
        </table>
        <div class="subtot"><span>Total a lista (24 lotes)</span><span class="num" id="lotTotal">—</span></div>
        <button class="btn" id="addLot">+ Agregar lote</button>
      </div>
    </div>

    <p class="note">Conceptos que se trasladan de Chivilcoy: la <b>autofinanciación</b> (las preventas al pozo cubren la obra, así que el capital propio inmovilizado es chico — más aún con obra liviana) y la <b>financiación al comprador</b> (lo cobrado antes de entregar no es crédito; solo financiás el saldo posterior a la entrega).</p>
  </section>

  <footer>
    <p><b>Nota.</b> Documento de trabajo de Agrimensura Umepay. Los costos son estimaciones preliminares en USD para cotizar localmente; los porcentajes de reparto y la mezcla de venta son supuestos a definir. La eventual cesión para laguna de retardo debe confirmarse con la oficina de loteos de Alta Gracia y la Dirección General de Catastro de Córdoba antes de comprometer obra o ventas.</p>
  </footer>
</div>

<script>
  var POZO_DISC = 0.25;
  var nf = new Intl.NumberFormat('es-AR');
  function fmt(n){ return (n<0?'-$':'$') + nf.format(Math.abs(Math.round(n))); }
  function $(id){ return document.getElementById(id); }

  var COSTS = [
    ['Apertura + ripio + cordón cuneta (pasaje 70 m)', 22000],
    ['Red eléctrica domiciliaria + conexiones', 38000],
    ['Alumbrado público', 14000],
    ['Red de agua + conexiones', 30000],
    ['Estudio de correntía + laguna de retardo', 12000],
    ['Forestación / varios de obra', 6000],
    ['Adoquinado del pasaje (opcional, para donación)', 22000],
    ['Derechos de visación (muni + Catastro)', 4000],
    ['Inmobiliario parcela origen (durante desarrollo)', 10000],
    ['Gestiones / cierre dominial / varios', 6000]
  ];
  var SURF = [975,688,573,516,519,625,595,597,659,849,822,647,704,590,664,945,908,926,926,1164,1454,854,881,865];

  function getAnchors(){
    var s = document.querySelectorAll('#anchors .asrf');
    var v = document.querySelectorAll('#anchors .aval');
    var a = [];
    for (var i=0;i<s.length;i++){ a.push([+s[i].value, +v[i].value]); }
    a.sort(function(x,y){ return x[0]-y[0]; });
    return a;
  }
  function priceFromRule(sup){
    var a = getAnchors();
    if (a.length < 2) return a.length ? a[0][1] : 0;
    for (var i=0;i<a.length-1;i++){
      if (sup <= a[i+1][0] || i === a.length-2){
        var slope = (a[i+1][1]-a[i][1])/(a[i+1][0]-a[i][0]);
        return a[i][1] + (sup - a[i][0])*slope;
      }
    }
    return a[0][1];
  }

  function costRow(concepto, monto){
    var tr = document.createElement('tr');
    tr.innerHTML =
      '<td><input class="cell-in c-con" type="text" value="'+concepto.replace(/"/g,'&quot;')+'"></td>'+
      '<td><input class="cell-in cell-num c-amt" type="number" step="1000" value="'+monto+'"></td>'+
      '<td style="width:34px;"><button class="del" title="Quitar">&times;</button></td>';
    return tr;
  }
  function lotRow(n, sup, precio){
    var tr = document.createElement('tr');
    tr.innerHTML =
      '<td class="lblcell">'+n+'</td>'+
      '<td><input class="cell-in cell-num l-srf" type="number" value="'+Math.round(sup)+'"></td>'+
      '<td><input class="cell-in cell-num l-prc" type="number" step="100" value="'+Math.round(precio)+'"></td>'+
      '<td style="width:34px;"><button class="del" title="Quitar">&times;</button></td>';
    return tr;
  }

  var costBody = $('costTable').querySelector('tbody');
  COSTS.forEach(function(c){ costBody.appendChild(costRow(c[0], c[1])); });
  var lotBody = $('lotTable').querySelector('tbody');
  SURF.forEach(function(s, i){ lotBody.appendChild(lotRow(i+1, s, Math.round(priceFromRule(s)))); });

  function sumClass(cls){
    var t = 0; document.querySelectorAll(cls).forEach(function(el){ t += (+el.value||0); }); return t;
  }
  function rrow(label, val, o){ o = o || {};
    var cls = 'r' + (o.t ? ' t' : '');
    var c = o.color ? ' style="color:'+o.color+'"' : '';
    return '<div class="'+cls+'"><span class="lbl">'+label+'</span><span'+c+'>'+val+'</span></div>';
  }

  function recompute(){
    var costos = sumClass('.c-amt');
    var lista  = sumClass('.l-prc');
    var pozo = +$('pozo').value, hugo = +$('hugo').value;
    var hf = +$('honorFijo').value||0, tog = $('honorTog').checked;
    $('pozoVal').textContent = pozo+'%'; $('hugoVal').textContent = hugo+'%';

    var ventas = lista * (1 - POZO_DISC*pozo/100);
    var parteHugo = ventas*hugo/100;
    var equipo = ventas - parteHugo;
    var ganDes = equipo - costos;
    var honor = tog ? (0.03*ventas + hf) : 0;
    var ganTot = ganDes + honor;
    var pos = ganTot >= 0;
    var col = pos ? 'var(--sage)' : 'var(--accent)';

    $('mVen').textContent = fmt(ventas);
    $('mCos').textContent = fmt(costos);
    $('mGan').textContent = fmt(ganTot); $('mGan').style.color = col;
    $('costTotal').textContent = fmt(costos);
    $('lotTotal').textContent = fmt(lista);

    $('bd').innerHTML =
      rrow('Ventas brutas (mezcla pozo/lista)', fmt(ventas)) +
      rrow('− Parte del dueño (Hugo)', fmt(-parteHugo)) +
      rrow('= Ingreso del equipo por lotes', fmt(equipo), {t:true}) +
      rrow('− Costos considerados', fmt(-costos)) +
      rrow('= Ganancia del desarrollo', fmt(ganDes), {t:true}) +
      (tog ? rrow('+ Honorarios internalizados (3% + fijos)', fmt(honor)) : '') +
      rrow('= Ganancia total del equipo', fmt(ganTot), {t:true, color:col});
  }

  var app = $('app');
  app.addEventListener('input', recompute);
  app.addEventListener('change', recompute);
  app.addEventListener('click', function(e){
    if (e.target.classList.contains('del')){
      e.target.closest('tr').remove(); recompute();
    }
  });
  $('addCost').addEventListener('click', function(){ costBody.appendChild(costRow('', 0)); recompute(); });
  $('addLot').addEventListener('click', function(){
    var n = lotBody.querySelectorAll('tr').length + 1;
    lotBody.appendChild(lotRow(n, 600, Math.round(priceFromRule(600)))); recompute();
  });
  $('recalc').addEventListener('click', function(){
    lotBody.querySelectorAll('tr').forEach(function(tr){
      var s = +tr.querySelector('.l-srf').value||0;
      tr.querySelector('.l-prc').value = Math.round(priceFromRule(s));
    });
    recompute();
  });
  document.querySelectorAll('.tab-btn').forEach(function(b){
    b.addEventListener('click', function(){
      document.querySelectorAll('.tab-btn').forEach(function(x){ x.classList.remove('active'); });
      document.querySelectorAll('.panel').forEach(function(x){ x.classList.remove('active'); });
      b.classList.add('active');
      $('p-'+b.dataset.tab).classList.add('active');
    });
  });
  recompute();
</script>
</body>
</html>
